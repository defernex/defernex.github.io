% MACRO

% Theorem etc...

\theoremstyle{plain}
\newtheorem{thm}{Theorem}[section]
%\newtheorem{thm}{Theorem}%[chapter]
\newtheorem{lem}[thm]{Lemma}
\newtheorem{prop}[thm]{Proposition}
\newtheorem{cor}[thm]{Corollary}
\newtheorem{conj}[thm]{Conjecture}
\newtheorem{problem}{Problem}
\newtheorem*{subproblem}{Sub-Problem}
\renewcommand{\theproblem}{\Alph{problem}}

\theoremstyle{definition}
\newtheorem{defi}[thm]{Definition}
\newtheorem{nt}[thm]{Notations}
\newtheorem*{maingoal}{Main Goal}
\newtheorem{property}[thm]{Property}
\newtheorem*{question}{Question}
\newtheorem{eg}[thm]{Example}
\newtheorem{egs}[thm]{Examples}


\theoremstyle{remark}
\newtheorem*{rmk}{Remark}
\newtheorem{su}[thm]{Setup}
\newtheorem{claim}[thm]{Claim}
\newtheorem{sk}[thm]{Sketch}
\newtheorem{appl}[thm]{Applications}
\newtheorem{comp}[thm]{Complement}
\newtheorem{comm}[thm]{Comment}
\newtheorem{ass}[thm]{Assumption}
\newtheorem{step}{Step}
\newtheorem{case}{Case}

